# ---- uni.fun config ----

# Doppler indexer GraphQL endpoint. The public TEST endpoint (Base Sepolia data)
# is the default. The production multichain endpoint is "available on request"
# from Whetstone — set it here once you have it.
NEXT_PUBLIC_DOPPLER_INDEXER=https://test.indexer.doppler.lol

# Optional WalletConnect project id (https://cloud.reown.com). If unset, only
# injected / Coinbase Wallet connectors are offered.
NEXT_PUBLIC_WALLETCONNECT_ID=

# Optional per-chain RPC overrides (public RPCs are used if unset).
NEXT_PUBLIC_RPC_MAINNET=
NEXT_PUBLIC_RPC_BASE=
NEXT_PUBLIC_RPC_UNICHAIN=
NEXT_PUBLIC_RPC_INK=
NEXT_PUBLIC_RPC_MONAD=

# Default referrer wallet (earns top-of-tree referral on bids routed through this
# mirror — mirrors the pump-v2-frontend mirror pattern).
NEXT_PUBLIC_DEFAULT_REFERRER=
