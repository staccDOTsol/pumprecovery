# ─────────────────────────────────────────────────────────────────────────────
# stacc.art / mirror frontend — environment template
#
# Copy to .env.local for local dev. On Vercel, set these in Project Settings →
# Environment Variables (the 1-click deploy prompts for the important one).
#
# RULE OF THUMB: anything NEXT_PUBLIC_* is shipped to the browser — NEVER put a
# real secret behind a NEXT_PUBLIC_ name. The shared-backend defaults are baked
# into next.config.js, so a fresh mirror works with ZERO of these set; values
# here (or in Vercel) override the baked defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── Per-mirror identity (safe to share) ──
# Your Solana wallet — earns the top-of-tree referral fee when a visitor arrives
# without a ?ref=. PROMPTED at 1-click deploy. Public on-chain address, not a secret.
NEXT_PUBLIC_DEFAULT_REFERRER=

# Optional brand override. Leave EMPTY to auto-use the current domain (URL bar).
NEXT_PUBLIC_BRAND=
# Optional canonical origin for OG tags / links. Empty = use the current origin.
NEXT_PUBLIC_SITE_URL=
# Sign-in challenge brand (verified by the shared backend). Default is neutral
# ("Pump ICO mirror"); only change if you also redeploy the backend to match.
NEXT_PUBLIC_SIGNIN_BRAND=

# ── Shared backends (safe to share; baked defaults live in next.config.js) ──
# Override only if you run your own.
NEXT_PUBLIC_API_URL=https://pump-api-server-6d0f94f3b186.herokuapp.com
NEXT_PUBLIC_CLIENT_API_URL=https://pump-client-server-ddd5e3eed248.herokuapp.com
NEXT_PUBLIC_PUMP_PROGRAM_ID=67LWrtDBPyZqS7SzCYZWBLgPBqZAG94GTfMWEBG2fnuV
NEXT_PUBLIC_ENABLE_ADD_LIQ=true
NEXT_PUBLIC_OPEN_VENUES_ON_CREATE=false

# ── RPC (RECOMMENDED: set your own) ──
# Browser-exposed (so technically public) but a BILLABLE credential — put your
# OWN Helius/Triton/etc key on a mirror so you don't drain someone else's quota.
# Falls back to public mainnet-beta (rate-limited; heavy reads like the LP
# registry + referral graph will not work without a real RPC).
NEXT_PUBLIC_SOLANA_API_URL=
NEXT_PUBLIC_SOLANA_API_URL2=

# Public OAuth client id for Twitter login (optional; bring your own for your
# own callback domain). Not a secret.
NEXT_PUBLIC_TWITTER_CLIENT_ID=

# ═════════════════════════════════════════════════════════════════════════════
#  SECRETS — server-only. REDACT from anything you share. NEVER prefix NEXT_PUBLIC_.
#  OPTIONAL for a mirror: without them, stats / airdrop / coin-creation-IPFS
#  features degrade, but core trading still works. Bring your OWN — do not reuse
#  production secrets, and rotate any that have ever been shared.
# ═════════════════════════════════════════════════════════════════════════════

# Supabase project URL (the URL itself is not secret).
SUPABASE_URL=
# Supabase service_role key — FULL DATABASE ACCESS, bypasses RLS. HIGHLY SECRET.
SUPABASE_KEY=
# Birdeye API key — billable. Powers /api/orca-tvl, /api/global-stats, /api/coin-flywheel.
BIRDEYE_API_KEY=
# Pinata (IPFS) keys — power coin-creation metadata pinning (/api/ipfs).
PINATA_API_KEY=
PINATA_SECRET_API_KEY=
